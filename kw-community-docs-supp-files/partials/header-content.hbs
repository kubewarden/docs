<header class="header">
  <nav class="navbar">
    <div class="navbar-brand">
      <div class="navbar-item">
        <a class=" navbar-logo" href="https://docs.kubewarden.io/" aria-label="Kubewarden Documentation Home"><img class="logo"
            src="{{uiRootPath}}/img/logo-kubewarden.svg" alt="Kubewarden logo"/></a>
      </div>
      {{#if env.SITE_SEARCH_PROVIDER}}
      <div class="navbar-item search hide-for-print">
        <div id="search-field" class="field">
          <label class="visual-search-label" for="search-input">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</label>
          <input label="Search" aria-label="Search" id="search-input" type="text" placeholder="Search the docs" {{#if page.home}} autofocus{{/if}}>
          <label class="filter checkbox" style="display: none">
            <input type="checkbox" data-facet-filter="component:{{page.component.name}}" checked> Only this project
          </label>
        </div>
      </div>
      {{/if}}
      <button class="navbar-burger" data-target="topbar-nav">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
    <div id="topbar-nav" class="navbar-menu">
      <div class="navbar-end">
        <div class="navbar-item has-dropdown is-hoverable">
          <div class="navbar-link">
            GitHub
          </div>
          <div class="navbar-dropdown">
            {{#with page.origin}}
            <a class="navbar-item" href="{{./webUrl}}" target="_blank"><i class="fab fa-github"></i>&nbsp;{{@root.page.origin.descriptor.title}} documentation</a>
            <a class="navbar-item" href="{{./webUrl}}/issues" target="_blank"><i class="fab fa-github"></i>&nbsp;Documentation issues</a>
            <a class="navbar-item" href="https://github.com/kubewarden/community/blob/main/CONTRIBUTING.md" target="_blank"><i class="fas fa-user-edit"></i>&nbsp;Contribute</a>
            {{/with}}
          </div>
        </div>
        <div class="navbar-item has-dropdown is-hoverable">
          <div class="navbar-link">
            Community
          </div>
          <div class="navbar-dropdown">
            <a class="navbar-item" href="https://kubernetes.slack.com/archives/kubewarden" target="_blank"><i class="fas fa-user-edit"></i>&nbsp;Slack</a>
            <a class="navbar-item" href="https://bsky.app/profile/kubewarden.io" target="_blank"><i class="fas fa-user-edit"></i>&nbsp;Bluesky</a>
            <a class="navbar-item" href="https://hachyderm.io/@kubewarden" target="_blank"><i class="fas fa-user-edit"></i>&nbsp;Mastodon</a>
          </div>
        </div>
      </div>
    </div>

    </div>
  </nav>
</header>

      </div>
    </div>

    </div>
  </nav>
</header>
